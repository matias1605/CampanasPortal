@model List<Campana>
@{
    ViewData["Title"] = "Campañas Comerciales";
}

<div class="page-header">
    <h1>Campañas Comerciales</h1>
    <p>Listado de todas las campañas activas, próximas y finalizadas.</p>
</div>

<table class="tabla">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Canal</th>
            <th>Descuento</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Acción</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nombre</td>
                <td>@c.Categoria</td>
                <td><span class="badge badge-@c.Estado.ToLower().Replace("ó","o")">@c.Estado</span></td>
                <td>@c.Canal</td>
                <td>@((c.DescuentoPct * 100).ToString("N0"))%</td>
                <td>@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                <td>@c.FechaFin.ToString("dd/MM/yyyy")</td>
                <td>
                    <a class="btn-sm"
                       asp-controller="Campanas"
                       asp-action="Detalle"
                       asp-route-id="@c.Id">Ver detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>
